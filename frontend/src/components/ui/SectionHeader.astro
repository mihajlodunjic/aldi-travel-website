---
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
}

const { eyebrow, title, text } = Astro.props;
---
<div class="section-header">
  {eyebrow ? <p class="eyebrow">{eyebrow}</p> : null}
  <div class="section-header__copy">
    <h2>{title}</h2>
    {text ? <p>{text}</p> : null}
  </div>
  <div class="double-rule" aria-hidden="true"></div>
</div>
