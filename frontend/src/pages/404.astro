---
import BaseLayout from "@/layouts/BaseLayout.astro";
---
<BaseLayout
  title="Stranica nije pronadjena | Aldi Travel demo"
  description="Tražena stranica nije pronadjena u Aldi Travel demo sajtu."
>
  <section class="section section--hero">
    <div class="container">
      <div class="page-intro">
        <p class="eyebrow">404</p>
        <h1>Ovaj put ne vodi do stranice.</h1>
        <p>Vratite se na katalog, destinacije ili pregled sacuvanih aranžmana i nastavite demo tok odatle.</p>
      </div>

      <div class="page-actions">
        <a class="button button--primary" href="/">
          Povratak na pocetnu
        </a>
        <a class="button button--secondary" href="/aranzmani">
          Otvori katalog
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
